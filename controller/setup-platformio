#!/bin/sh
set -eu

PROJECT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ ! -x "$PROJECT_DIR/.venv/bin/python" ]; then
  python3 -m venv "$PROJECT_DIR/.venv"
fi

"$PROJECT_DIR/.venv/bin/python" -m pip install --upgrade platformio
"$PROJECT_DIR/pio" pkg install

echo "PlatformIO is ready. Use ./pio run or ./pio run -t upload."
